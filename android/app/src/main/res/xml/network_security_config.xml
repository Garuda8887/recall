<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- System CA store (public CAs like Let's Encrypt) -->
            <certificates src="system"/>
            <!-- User-installed CA certs — required for self-hosted servers
                 using Caddy internal TLS or mkcert local CAs.
                 Android 7+ blocks user CAs in apps by default. -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
